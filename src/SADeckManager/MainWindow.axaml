<Window
        x:Class="SADeckManager.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SADeckManager"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="SA Deck Manager"
        d:DesignHeight="620"
        d:DesignWidth="980"
        mc:Ignorable="d">
        <Grid Margin="16" RowDefinitions="Auto,Auto,*">
                <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="SA Deck Manager - Mods" />

                <Grid
                        Grid.Row="1"
                        Margin="0,12,0,12"
                        ColumnDefinitions="*,Auto,Auto,Auto"
                        ColumnSpacing="8">
                        <TextBox
                                x:Name="ProfileNameTextBox"
                                VerticalContentAlignment="Center"
                                Watermark="Profile name (example: default)" />
                        <Button
                                x:Name="RefreshButton"
                                Grid.Column="1"
                                Click="OnRefreshClick"
                                Content="Refresh" />
                        <Button
                                x:Name="SaveProfileButton"
                                Grid.Column="2"
                                Click="OnSaveProfileClick"
                                Content="Save Profile" />
                        <Button
                                x:Name="LoadProfileButton"
                                Grid.Column="3"
                                Click="OnLoadProfileClick"
                                Content="Load Profile" />
                </Grid>

                <Grid
                        Grid.Row="2"
                        ColumnDefinitions="2*,3*"
                        ColumnSpacing="12">
                        <Border
                                Padding="10"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel>
                                        <TextBlock
                                                x:Name="GameInfoText"
                                                FontFamily="Monospace"
                                                TextWrapping="Wrap" />
                                        <TextBlock
                                                x:Name="StatusText"
                                                FontSize="12"
                                                Opacity="0.8"
                                                TextWrapping="Wrap" />
                                </StackPanel>
                        </Border>

                        <Border
                                Grid.Column="1"
                                Padding="10"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel>
                                        <TextBlock
                                                Margin="0,0,0,8"
                                                FontWeight="SemiBold"
                                                Text="Mods" />
                                        <ScrollViewer>
                                                <ItemsControl x:Name="ModsItemsControl">
                                                        <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="local:ModItem">
                                                                        <CheckBox
                                                                                Margin="0,2,0,2"
                                                                                Checked="OnModCheckedChanged"
                                                                                Content="{Binding Label}"
                                                                                IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                                Tag="{Binding Id}"
                                                                                Unchecked="OnModCheckedChanged" />
                                                                </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                        </ScrollViewer>
                                </StackPanel>
                        </Border>
                </Grid>

        </Grid>
</Window>
